    module Test;
    import Subprocess;

    test : IO ();
    test = (
        println("Run \"ls -l -r\".");;
        let (_, exit_status) = *run_with_stream("ls", ["ls", "-l", "-r"], |(stdin, stdout, stderr)| (
            let output = *read_string(stdout); // Read standard output of the command.
            println(output).lift
        )).try(exit_with_msg(1));
        assert_eq(|_|"", exit_status.as_exit, 0_U8);;

        println("Run \"sed s/w/W/\" and write \"Hello world!\" to the standard input.");;
        let (_, exit_status) = *run_with_stream("sed", ["/usr/bin/sed", "s/w/W/"], |(stdin, stdout, stderr)| (
            write_string(stdin, "Hello world!");;
            close_file(stdin).lift;; // Send EOF.
            let output = *read_string(stdout); // Read standard output of the command.
            println(output).lift
        )).try(exit_with_msg(1));
        assert_eq(|_|"", exit_status.as_exit, 0_U8);;

        // Regression test: large stderr (>64 KiB pipe buffer) plus small stdout used to deadlock
        // because `run_string` drained stdout fully before stderr. The child blocked on stderr
        // write, the parent on stdout read, and neither could make progress.
        // We pick 100_000 > 65_536 (Linux default pipe buffer) to exercise the deadlock path.
        println("Run \"sh -c '...'\" that writes 100_000 bytes to stderr (regression for stderr-overflow deadlock).");;
        let ((stdout_str, stderr_str), exit_status) = *run_string(
            "sh",
            ["sh", "-c", "printf '%*s' 100000 '' 1>&2; echo done"],
            ""
        ).try(exit_with_msg(1));
        assert_eq(|_|"stderr length", stderr_str.@size, 100000);;
        assert_eq(|_|"stdout length", stdout_str.@size, 5);; // "done\n"
        assert_eq(|_|"exit status", exit_status.as_exit, 0_U8);;

        // Mirror case: large stdout plus small stderr. Symmetric deadlock if the read order
        // were reversed; with concurrent reads it must just work.
        println("Run \"sh -c '...'\" that writes 100_000 bytes to stdout (mirror regression).");;
        let ((stdout_str, stderr_str), exit_status) = *run_string(
            "sh",
            ["sh", "-c", "printf '%*s' 100000 ''; echo err 1>&2"],
            ""
        ).try(exit_with_msg(1));
        assert_eq(|_|"stdout length", stdout_str.@size, 100000);;
        assert_eq(|_|"stderr length", stderr_str.@size, 4);; // "err\n"
        assert_eq(|_|"exit status", exit_status.as_exit, 0_U8);;

        // Both streams large: each exceeds the pipe buffer.
        println("Run \"sh -c '...'\" that writes 100_000 bytes to both stdout and stderr.");;
        let ((stdout_str, stderr_str), exit_status) = *run_string(
            "sh",
            ["sh", "-c", "printf '%*s' 100000 ''; printf '%*s' 100000 '' 1>&2"],
            ""
        ).try(exit_with_msg(1));
        assert_eq(|_|"stdout length", stdout_str.@size, 100000);;
        assert_eq(|_|"stderr length", stderr_str.@size, 100000);;
        assert_eq(|_|"exit status", exit_status.as_exit, 0_U8);;

        // Sanity: small input/output via run_string still works.
        println("Run \"sed s/w/W/\" via run_string with small input.");;
        let ((stdout_str, stderr_str), exit_status) = *run_string(
            "sed",
            ["/usr/bin/sed", "s/w/W/"],
            "Hello world!"
        ).try(exit_with_msg(1));
        assert_eq(|_|"stdout content", stdout_str, "Hello World!");;
        assert_eq(|_|"stderr content", stderr_str, "");;
        assert_eq(|_|"exit status", exit_status.as_exit, 0_U8);;

        pure()
    );